{
  "$schema": "https://json.schemastore.org/lerna.json",
  "version": "independent",
  "command": {
    "publish": {
      "conventionalCommits": true,
      "message": "chore(release): publish",
      "allowBranch": "main",
      "ignoreChanges": ["**/*.spec.ts", "**/*.test.ts", "**/test/**"]
    }
  },
  "packages": ["packages/*"]
}
