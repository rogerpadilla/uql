{
  "private": true,
  "type": "module",
  "sideEffects": false,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "release": "bun run build && lerna publish",
    "release.patch": "bun run release patch && git pull && git push",
    "release.minor": "bun run release minor && git pull && git push",
    "release.major": "bun run release major && git pull && git push",
    "release.current": "bun run release from-package && git pull && git push",
    "check": "bun run --parallel ts lint.fix",
    "ts": "tsc --noEmit",
    "build": "lerna run build",
    "lint": "biome check .",
    "lint.fix": "biome check . --fix",
    "test": "npm run test:vitest && npm run test:bun",
    "test:vitest": "vitest run --coverage",
    "test:bun": "bun test --coverage-dir=coverage/bun ./packages/uql-orm/src/bunSql/",
    "test.watch": "vitest",
    "test.focus": "vitest run -t 'shouldMergeJsonBooleanField'",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "header-max-length": [
        2,
        "always",
        300
      ],
      "subject-case": [
        0
      ],
      "subject-full-stop": [
        0
      ]
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@swc/core": "^1.15.24",
    "@swc/helpers": "^0.5.21",
    "@types/bun": "^1.3.11",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "lerna": "^9.0.7",
    "mongodb-memory-server": "11.0.1",
    "rimraf": "6.1.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.2",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "author": "Roger Padilla"
}
