{
  "private": true,
  "version": "3.8.4",
  "type": "module",
  "sideEffects": false,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "release.patch": "bun run build && lerna publish patch && git pull && git push",
    "release.minor": "bun run build && lerna publish minor && git pull && git push",
    "release.major": "bun run build && lerna publish major && git pull && git push",
    "check": "bun run --parallel ts lint.fix",
    "ts": "tsc --noEmit",
    "build": "lerna run build",
    "lint": "biome check .",
    "lint.fix": "biome check . --fix",
    "test": "vitest run --coverage",
    "test.watch": "vitest",
    "test.focus": "vitest run -t 'shouldInsertOneAndCascadeOneToOne' packages/core/src/mongo/mongodbQuerier.test.ts"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@swc/core": "^1.15.18",
    "@swc/helpers": "^0.5.19",
    "@types/bun": "^1.3.10",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "copyfiles": "^2.4.1",
    "lerna": "^9.0.5",
    "mongodb-memory-server": "11.0.1",
    "rimraf": "6.1.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.0-beta",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "author": "Roger Padilla"
}
