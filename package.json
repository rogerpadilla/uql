{
  "private": true,
  "type": "module",
  "sideEffects": false,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "release": "bun run build && lerna publish",
    "release.patch": "bun run release patch && git push --follow-tags",
    "release.minor": "bun run release minor && git push --follow-tags",
    "release.major": "bun run release major && git push --follow-tags",
    "release.current": "bun run release from-package && git push --follow-tags",
    "ts": "tsc --noEmit",
    "build": "lerna run build",
    "lint": "biome check .",
    "lint.fix": "biome check . --fix",
    "test": "bun run test:vitest && bun run test:bun",
    "test:vitest": "vitest run --coverage",
    "test:bun": "bun test --coverage-dir=coverage/bun ./packages/uql-orm/src/bunSql/",
    "test.watch": "vitest",
    "test.focus": "vitest run -t 'shouldMergeJsonBooleanField'"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "header-max-length": [
        2,
        "always",
        500
      ],
      "subject-case": [
        0
      ],
      "subject-full-stop": [
        0
      ]
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@swc/core": "^1.15.46",
    "@types/bun": "^1.3.14",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "lerna": "^9.0.7",
    "lint-staged": "^17.2.0",
    "mongodb-memory-server": "11.2.0",
    "rimraf": "6.1.3",
    "supertest": "^7.2.2",
    "typescript": "^7.0.2",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,css,md}": [
      "biome check --fix --no-errors-on-unmatched"
    ]
  }
}
