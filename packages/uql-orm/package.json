{
  "name": "uql-orm",
  "homepage": "https://uql-orm.dev",
  "description": "Fast, type-safe TypeScript ORM — one API for every database",
  "license": "MIT",
  "version": "0.7.7",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "uql-migrate": "./dist/migrate/bin.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./dialect": "./dist/dialect/index.js",
    "./entity": "./dist/entity/index.js",
    "./querier": "./dist/querier/index.js",
    "./type": "./dist/type/index.js",
    "./type/migratorDialect": "./dist/type/migratorDialect.js",
    "./util": "./dist/util/index.js",
    "./namingStrategy": "./dist/namingStrategy/index.js",
    "./migrate": "./dist/migrate/index.js",
    "./options": "./dist/options.js",
    "./test": "./dist/test/index.js",
    "./mysql": "./dist/mysql/index.js",
    "./postgres": "./dist/postgres/index.js",
    "./postgres/wireCapabilities": "./dist/postgres/postgresWireDriverCapabilities.js",
    "./cockroachdb": "./dist/cockroachdb/index.js",
    "./maria": "./dist/maria/index.js",
    "./sqlite": "./dist/sqlite/index.js",
    "./mongo": "./dist/mongo/index.js",
    "./express": "./dist/express/index.js",
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/uql-browser.min.js"
    },
    "./libsql": "./dist/libsql/index.js",
    "./neon": "./dist/neon/index.js",
    "./d1": "./dist/d1/index.js",
    "./bunSql": "./dist/bunSql/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepack": "cp ../../README.md . && cp ../../CHANGELOG.md .",
    "postpack": "rm README.md CHANGELOG.md",
    "compile.browser": "bunchee --clean false --no-dts ./src/browser/index.ts --sourcemap -o ./dist/browser/uql-browser.min.js 2>/dev/null",
    "build": "bun run clean && tsc -b tsconfig.build.json && bun run compile.browser",
    "start": "tsc --watch",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "jiti": "^2.6.1",
    "reflect-metadata": "^0.2.2",
    "sqlstring": "^2.3.3",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@libsql/client": ">=0.6.0",
    "@neondatabase/serverless": ">=0.9.0",
    "better-sqlite3": ">=9.0.0",
    "express": ">=5.0.0",
    "mariadb": ">=3.0.0",
    "mongodb": ">=6.0.0",
    "mysql2": ">=3.0.0",
    "pg": ">=8.0.0",
    "pg-query-stream": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "mariadb": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "pg-query-stream": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "@libsql/client": {
      "optional": true
    },
    "@neondatabase/serverless": {
      "optional": true
    }
  },
  "devDependencies": {
    "@libsql/client": "^0.17.2",
    "@neondatabase/serverless": "^1.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "@types/sqlstring": "^2.3.2",
    "better-sqlite3": "^12.8.0",
    "bunchee": "^6.9.4",
    "express": "^5.2.1",
    "mariadb": "^3.5.2",
    "mongodb": "^7.1.1",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "pg-query-stream": "^4.14.0"
  },
  "author": "Roger Padilla",
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerpadilla/uql.git"
  },
  "bugs": {
    "url": "https://github.com/rogerpadilla/uql/issues"
  },
  "keywords": [
    "orm",
    "query-builder",
    "data-mapper",
    "persistence",
    "database",
    "db",
    "typesafe",
    "typescript-orm",
    "javascript-orm",
    "mariadb",
    "mariadb-orm",
    "mysql",
    "mysql-orm",
    "postgresql",
    "postgresql-orm",
    "sqlite",
    "sqlite-orm",
    "cockroachdb",
    "cockroachdb-orm",
    "mongodb",
    "mongodb-orm",
    "entity",
    "dao",
    "transaction",
    "repository",
    "service",
    "migrations"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "2c04474548a5aa48340dbccfeb9dfdd460cbe2b4"
}
